---
profile: moderate

exclude_paths:
  - .venv/
  - .github/
  - .cache/
  - ansible/molecule-template/   # wzorzec z placeholderem roli (REPLACE_WITH_ROLE_NAME)

# yamllint pilnuje formatu YAML osobno
skip_list:
  - yaml[line-length]

# Reguły, które chcemy mieć jako twarde, gdy pojawią się role
enable_list:
  - no-changed-when
  - fqcn-builtins
